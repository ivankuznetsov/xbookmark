# X (Twitter) API — required
X_CLIENT_ID=your-x-client-id
# Optional: X confidential client secret (only if your X app is "confidential")
X_CLIENT_SECRET=
# OAuth 2.0 PKCE callback — must match what's registered on your X app
X_REDIRECT_URI=http://127.0.0.1:7799/callback
# Numeric X user id whose bookmarks we read (not the @handle).
X_USER_ID=
# Tokens — populated automatically by `xbookmark auth login`. Do NOT commit.
X_ACCESS_TOKEN=
X_REFRESH_TOKEN=
X_TOKEN_EXPIRES_AT=

# Vault — defaults to $XDG_DATA_HOME/xbookmark-vault on Linux,
# ~/Library/Application Support/xbookmark-vault on macOS.
XBOOKMARK_VAULT=

# Logs — defaults to $XDG_STATE_HOME/xbookmark on Linux,
# ~/Library/Logs/xbookmark on macOS.
XBOOKMARK_LOGS_DIR=

# Codex (CLI used for all LLM calls). Default: `codex` in PATH.
CODEX_BIN=codex

# Whisper binary (whisper.cpp `whisper-cli`, `whisper`, or `faster-whisper`).
# Auto-probed when unset.
WHISPER_BIN=
WHISPER_MODEL=base.en

# QMD binary for indexing & search.
QMD_BIN=qmd

# Scheduler defaults
XBOOKMARK_DAILY_TIME=06:00
XBOOKMARK_MIN_RUN_INTERVAL_HOURS=20
XBOOKMARK_CONCURRENCY=3
