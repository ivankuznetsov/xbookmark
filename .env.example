# This file is the committed template. It MUST stay empty of real
# credentials. Copy it to `.env` (gitignored) and fill values there only.
# Editing this file with real X API credentials and committing it will
# leak them publicly.

# X API (OAuth 2.0 with PKCE)
X_CLIENT_ID=                                    # leave blank here; fill only in .env
X_CLIENT_SECRET=                                # leave blank here; only needed in .env for confidential-client app types
X_REDIRECT_URI=http://127.0.0.1:8765/callback   # default auth login port; register another port if using --port

# Where the markdown vault lives (leading ~ is expanded by xbookmark)
OBSIDIAN_VAULT_PATH=~/Vaults/xbookmark

# Whisper transcription
WHISPER_BACKEND=whisper.cpp   # or faster-whisper
WHISPER_MODEL=base.en         # tiny.en, base.en, small.en, medium.en, tiny, base, small, medium, or large-v3

# codex CLI profile for enrichment
CODEX_PROFILE=default
