#!/usr/bin/env ruby
# frozen_string_literal: true

lib_dir = File.expand_path("../lib", __dir__)
$LOAD_PATH.unshift(lib_dir) unless $LOAD_PATH.include?(lib_dir)

require "xbookmark"
require "xbookmark/cli"

if ARGV.empty? && $stdin.respond_to?(:tty?) && $stdin.tty? && !Xbookmark::CLI::Setup.first_run_configured?
  exit Xbookmark::CLI::Setup.first_run_check!
end

Xbookmark::CLI.start(ARGV)
